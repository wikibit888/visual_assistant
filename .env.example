# Visual Assistant v0.1 · 密钥与 MOCK 开关（契约六/七）
# 复制为 .env 后填值。规则：密钥只在此处，代码禁硬编码；config.yaml 不放密钥。
# .env 已在 .gitignore，切勿提交真实密钥。

# ── 模型供应商密钥（按所选 provider 填；M0 默认 planner=deepseek, vision/asr/tts=gemini）──
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# Open-Meteo 天气无需 key

# ── MOCK 开关（契约六）：置 1 则该模块/工具脱依赖、可独立运行；未设或非 1 即真实路径 ──
MOCK_VISION=0     # C 视觉工具读 fixture
MOCK_WEATHER=0    # weather.get 返回写死兜底
MOCK_ASR=0        # B ASR 适配器
MOCK_TTS=0        # B TTS 适配器
MOCK_PLANNER=0    # A planner 走固定脚本输出，不调 LLM
MOCK_LLM=0        # E/通用 LLM 调用
