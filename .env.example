# Visual Assistant v0.1 · 密钥与 MOCK 开关（契约·MOCK/配置；Live 版）
# 复制为 .env 后填值。规则：密钥只在此处，代码禁硬编码；config.yaml 不放密钥。
# .env 已在 .gitignore，切勿提交真实密钥。

# ── 模型供应商密钥（默认 live/vision=gemini；切 OpenAI Live 才需 OPENAI_API_KEY）──
GEMINI_API_KEY=
OPENAI_API_KEY=
# Open-Meteo 天气无需 key

# ── MOCK 开关（契约·MOCK）：置 1 则该依赖脱真实、可独立运行；未设或非 1 即真实路径 ──
MOCK_LIVE=0       # Live 大脑走脚本/回声桩，不连 realtime API
MOCK_VISION=0     # 视觉工具读 fixture，不抓真帧
MOCK_WEATHER=0    # weather_get 返回写死兜底
